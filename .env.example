# ── LuxeWood API ──────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env.

NODE_ENV=development
PORT=4000

# Comma-separated list of origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# REQUIRED in production — long random string (64+ hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=

# Key required by GET /api/quotes (lead export)
ADMIN_API_KEY=

# Firebase Admin — download from:
# Firebase console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT=./server/serviceAccountKey.json
FIREBASE_DB_URL=https://luxewood-b7b97-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=luxewood-b7b97

# ── OTP via Firebase Phone Auth (recommended) ─────────────────
# Firebase sends the SMS. Paste your Firebase WEB config:
# Console -> Project settings -> General -> Your apps -> Web -> SDK config.
# Also enable: Console -> Authentication -> Sign-in method -> Phone.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=luxewood-b7b97.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=luxewood-b7b97
VITE_FIREBASE_APP_ID=

# ── SMS delivery for the LOCAL fallback flow (optional) ───────
# Only used when Firebase web config above is empty.
# 'none' = OTP shown on screen (development only).
# fast2sms — https://www.fast2sms.com -> Dev API -> API key
# msg91    — https://msg91.com (needs a DLT-approved OTP template)
# twilio   — https://www.twilio.com (international)
SMS_PROVIDER=none

FAST2SMS_API_KEY=

MSG91_AUTHKEY=
MSG91_TEMPLATE_ID=

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
